   "source": [
    "import feedparser\n",
    "\n",
    "rss_url = \"https://webapi.yanoshin.jp/tdnet/\"\n",
    "feed = feedparser.parse(rss_url)\n",
    "\n",
    "for entry in feed.entries:\n",
    "    title = entry.get(\"title\", \"\")\n",
    "    link = entry.get(\"link\", \"\")\n",
    "    print(title, link)"
   ]
