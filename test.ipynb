    "import feedparser\n",
    "\n",
    "rss_url = \"https://webapi.yanoshin.jp/webapi/edinet/list/E38180.rss\"\n",
    "feed = feedparser.parse(rss_url)\n",
    "\n",
    "print(len(feed.entries))  # 取得できているか確認\n",
    "for entry in feed.entries[:5]:\n",
    "    print(entry.title, entry.link, entry.published)"
